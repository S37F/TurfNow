# ===========================================
# TurfNow - Backend (Render Web Service)
# Deploy: connect repo in Render, use render.yaml or set Root Directory = server
# Dashboard → Environment → add the variables below (especially sync: false secrets)
# ===========================================

PORT=5000
NODE_ENV=development

# Supabase → Settings → Database → Connection string (URI, use "Transaction" pooler if needed)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS: your Vercel URL (comma-separated for multiple)
FRONTEND_URL=http://localhost:3001

# ===========================================
# Email (optional)
# ===========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here
EMAIL_FROM=TurfNow <your-email@gmail.com>
