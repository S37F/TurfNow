# TurfNow — API server
# Copy to .env in the server folder

PORT=5000
NODE_ENV=development

# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.ap-south-1.aws.neon.tech/turfnow?sslmode=require

# JWT signing secret — required in production, at least 16 characters
JWT_SECRET=change-me-to-a-long-random-string

# Allowed browser origins (comma-separated). Must include your Vite URL in dev.
FRONTEND_URL=http://localhost:3001

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here
EMAIL_FROM=TurfNow <your-email@gmail.com>
